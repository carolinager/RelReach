// toy example from Ex 7.2

mdp

module main
    s : [1..5]; // 1: s1, 2: s2, 3: t, 4: s', 5: t'
    [] s=1 -> 1/3 : (s'=2) + 1/3 : (s'=3) + 1/3 : (s'=4);
    [] s=2 -> 2/3 : (s'=4) + 1/3 : (s'=5);
    [] s=3 -> 1 : true;
    [alpha] s=4 -> 1 : (s'=3);
    [beta] s=4 -> 1 : (s'=5);
    [gamma] s=5 -> 1 : (s'=2);
    [delta] s=5 -> 1 : true;
endmodule

label "init1" = (s=1);
label "init2" = (s=2);
label "init3" = (s=1);
label "init4" = (s=1);

label "t" = (s=3);
label "tp" = (s=5);
